{
  "name": "ardichoke-arpwatch",
  "version": "0.4.0",
  "author": "ardichoke",
  "license": "Apache-2.0",
  "summary": "Install and manage arpwatch",
  "source": "https://github.com/ardichoke/puppet-arpwatch",
